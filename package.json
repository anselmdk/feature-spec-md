{
  "name": "@anselmdk/feature-spec-md",
  "version": "0.7.0",
  "description": "Markdown specs for AI-assisted, testable spec driven development across model, feature, stack, and design documents.",
  "type": "module",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/anselmdk/feature-spec-md.git"
  },
  "bin": {
    "feature-spec-md": "dist/cli.js"
  },
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./specDocuments": {
      "types": "./dist/specDocuments.d.ts",
      "import": "./dist/specDocuments.js"
    },
    "./playwright": {
      "types": "./dist/playwright.d.ts",
      "import": "./dist/playwright.js"
    }
  },
  "files": [
    "dist",
    "src/mocks",
    "README.md",
    "SPEC_FORMAT.md",
    "docs",
    "templates",
    "examples",
    "LICENSE"
  ],
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "tsc -p tsconfig.build.json",
    "prepare": "npm run build",
    "dev": "tsx src/cli.ts",
    "spec": "tsx src/cli.ts check",
    "spec:init": "tsx src/cli.ts init",
    "spec:report": "tsx src/cli.ts report",
    "report:mock": "tsx src/mockReports.ts",
    "format": "prettier --write .",
    "check:example": "tsx src/cli.ts check --specs examples/**/*.feature.md --tests \"\" --require-scenario-coverage=false --require-rule-coverage=false --require-model-coverage=false",
    "report:example": "tsx src/cli.ts report --specs examples/**/*.feature.md --tests tests/**/*.test.ts --out test-results/feature-spec-report/index.html",
    "test": "npm run test:unit && npm run test:playwright",
    "test:unit": "tsx --test tests/**/*.test.ts",
    "test:playwright": "playwright install chromium && playwright test",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "verify": "npm run typecheck && npm test && npm run build && npm run check:example"
  },
  "keywords": [
    "markdown",
    "bdd",
    "gherkin",
    "playwright",
    "specification",
    "spec-driven-development",
    "testing"
  ],
  "license": "MIT",
  "devDependencies": {
    "@playwright/test": "^1.60.0",
    "@types/node": "^25.3.2",
    "prettier": "^3.8.4",
    "tsx": "^4.21.0",
    "typescript": "^5.9.3"
  }
}
